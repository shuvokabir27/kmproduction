<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Route all requests through index.php for crawler detection
  RewriteRule ^index\.html$ - [L]
  RewriteRule ^index\.php$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.php [L]
</IfModule>
